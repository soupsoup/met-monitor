    "text": "\ufd3f\u0648\u064e\u062c\u064e\u0639\u064e\u0644\u0652\u0646\u064e\u0627 \u0628\u064e\u0639\u0652\u0636\u064e\u0643\u064f\u0645\u0652 \u0644\u0650\u0628\u064e\u0639\u0652\u0636\u064d \u0641\u0650\u062a\u0652\u0646\u064e\u0629\u064b \u0623\u064e\u062a\u064e\u0635\u0652\u0628\u0650\u0631\u064f\u0648\u0646\u064e\ufd3e\n\n\u0627\u0644\u062a\u0641\u0643\u0643 \u0627\u0644\u0623\u0633\u0631\u064a \u0648\u0627\u0644\u062e\u0644\u0627\u0641\u0627\u062a \u0645\u0648\u062c\u0648\u062f\u0629 \u062d\u0642\u064a\u0642\u0629 \n\u0644\u0643\u0646 \u0645\u0634\u0643\u0644\u062a\u0646\u0627 \u0627\u0644\u062a\u064a \u0646\u0623\u0628\u0649 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0641 \u0641\u064a\u0647\u0627 \u0623\u0646 \u0627\u0644\u0641\u0631\u062f \u0628\u062f\u0644\u064b\u0627 \u0645\u0646 \u0623\u0646 \u064a\u062d\u0627\u0648\u0644 \u0627\u0643\u062a\u0634\u0627\u0641 \u0639\u064a\u0648\u0628\u0647 \u0648\u0625\u0635\u0644\u0627\u062d \u0646\u0641\u0633\u0647 \u0648\u064a\u0635\u0628\u0631 \u0639\u0644\u0649 \u0639\u0644\u0627\u0642\u0627\u062a\u0647 \u0645\u0639 \u0623\u0647\u0644\u0647 \u0648\u0623\u0642\u0627\u0631\u0628\u0647 \u0648\u0645\u062d\u064a\u0637\u0647\u060c \u0627\u0644\u0623\u0633\u0647\u0644 \u0623\u0646\u0647 \u064a\u0631\u0645\u064a \u0627\u0644\u0633\u0628\u0628 \u0639\u0644\u064a\u0647\u0645 \u062b\u0645 \u064a\u0642\u0627\u0637\u0639\u0647\u0645!\n\n\u0645\u0634\u0643\u0644\u0629 \u0623\u062e\u0631\u0649 \u0623\u064a\u0636\u064b\u0627 \u0646\u0647\u0631\u0628 \u0645\u0646 \u0645\u0648\u0627\u062c\u0647\u062a\u0647\u0627 \u0623\u0646 \u0623\u063a\u0644\u0628\u0646\u0627 \"\u0637\u0644\u0651\u0627\u0628 \u062f\u0646\u064a\u0627\"! \u0646\u0628\u062a\u063a\u064a \u0627\u0644\u062d\u064a\u0627\u0629 \u0648\u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u062a\u0623\u062a\u064a \u0633\u0647\u0644\u0629\u060c \u0646\u062d\u0630\u0641 \u0645\u0646 \u0644\u0627 \u064a\u0639\u062c\u0628\u0646\u0627\u060c \u0648\u0646\u0633\u062a\u0628\u062f\u0644\u0647\u0645 \u0628\u0633\u0647\u0648\u0644\u0629\u060c \u0648\u0646\u0639\u062a\u0642\u062f \u0623\u0646\u0646\u0627 \u0628\u0647\u0630\u0627 \u0633\u0646\u0631\u062a\u0627\u062d \u0648\u0646\u0633\u064a\u0651\u0631 \u0627\u0644\u0623\u0645\u0631 \u0639\u0644\u0649 \u0631\u063a\u0628\u062a\u0646\u0627\n\n\u0644\u0643\u0646 \u0627\u0644\u0642\u0631\u0622\u0646 \u0628\u062a\u0631\u0627\u0628\u0637 \u0622\u064a\u0627\u062a\u0647 \u064a\u0639\u0644\u0651\u0645\u0643 \u0623\u0646 \u0627\u0644\u062f\u0646\u064a\u0627 \u062f\u0627\u0631 \u0627\u0628\u062a\u0644\u0627\u0621\u060c \u0627\u0628\u062a\u0644\u0627\u0621 \u0628\u0628\u0639\u0636\u060c \u0648\u0627\u0628\u062a\u0644\u0627\u0621 \u0628\u0646\u0641\u0633\u0643\u060c \u0648\u0627\u0628\u062a\u0644\u0627\u0621 \u0628\u0627\u0644\u0623\u062d\u0648\u0627\u0644\u060c \u0648\u0627\u0628\u062a\u0644\u0627\u0621 \u0628\u0627\u0644\u062f\u064a\u0646\u060c \u0648\u0627\u0628\u062a\u0644\u0627\u0621 \u0628\u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a.. \n\n\ufd3f\u0648\u064e\u0644\u064e\u0627 \u062a\u064e\u0633\u0652\u062a\u064e\u0648\u0650\u064a \u0627\u0644\u0652\u062d\u064e\u0633\u064e\u0646\u064e\u0629\u064f \u0648\u064e\u0644\u064e\u0627 \u0627\u0644\u0633\u064e\u0651\u064a\u0650\u0651\u0626\u064e\u0629\u064f \u06da \u0627\u062f\u0652\u0641\u064e\u0639\u0652 \u0628\u0650\u0627\u0644\u064e\u0651\u062a\u0650\u064a \u0647\u0650\u064a\u064e \u0623\u064e\u062d\u0652\u0633\u064e\u0646\u064f \u0641\u064e\u0625\u0650\u0630\u064e\u0627 \u0627\u0644\u064e\u0651\u0630\u0650\u064a \u0628\u064e\u064a\u0652\u0646\u064e\u0643\u064e \u0648\u064e\u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f \u0639\u064e\u062f\u064e\u0627\u0648\u064e\u0629\u064c \u0643\u064e\u0623\u064e\u0646\u064e\u0651\u0647\u064f \u0648\u064e\u0644\u0650\u064a\u064c\u0651 \u062d\u064e\u0645\u0650\u064a\u0645\u064c \u06dd \u0648\u064e\u0645\u064e\u0627 \u064a\u064f\u0644\u064e\u0642\u064e\u0651\u0627\u0647\u064e\u0627 \u0625\u0650\u0644\u064e\u0651\u0627 \u0627\u